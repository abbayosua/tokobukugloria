# Supabase Database
# Pooler connection (for serverless/edge functions)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Direct connection (for migrations)
DIRECT_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase Keys (get these from your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
